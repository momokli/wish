# wish — environment variables
# Copy to .env and fill in secrets. On the server, secrets live in
# ~/.config/wish/config.toml. Env vars override TOML.
#
# Load order: env vars > .env > ~/.config/wish/config.toml > defaults
# --------------------------------------------------------------------

# ── Server ──────────────────────────────────────────────────────────
# WISH_PORT=8700                       # HTTP listen port (default: 3000)
# DATABASE_URL=sqlite:wish.db?mode=rwc # default: sqlite:wish.db?mode=rwc

# ── Spotify (client credentials, no OAuth) ──────────────────────────
WISH_SPOTIFY_CLIENT_ID=
WISH_SPOTIFY_CLIENT_SECRET=

# ── Deemix (deezer download via deemix-pyweb Docker) ────────────────
# WISH_DEEMIX_BASE_URL=http://localhost:6595  # default: http://localhost:6596
WISH_DEEMIX_ARL=

# ── Download ────────────────────────────────────────────────────────
# WISH_DOWNLOAD_OUTPUT_DIR=/opt/download-service/downloads
# WISH_DOWNLOAD_MAX_PER_USER=5           # default: 5 (rate limit per browser session)

# ── Logging ─────────────────────────────────────────────────────────
# RUST_LOG=wish=info,tower_http=info    # default

# ── yt-dlp ──────────────────────────────────────────────────────────
# WISH_DOWNLOAD_YTDLP_COOKIES=/home/momo/wish/cookies-youtube.txt # path to youtube cookies
# WISH_DOWNLOAD_YTDLP_PROXY=socks5://127.0.0.1:1080               # yt-dlp SOCKS5 proxy

# Download concurrency & timeouts
WISH_DOWNLOAD_MAX_CONCURRENT=3
WISH_DOWNLOAD_MAX_RETRIES=3
WISH_DOWNLOAD_TIMEOUT_SECS=300

# WISH_DOWNLOAD_MAX_CONCURRENT=3           # max parallel downloads (default: 3)
# WISH_DOWNLOAD_MAX_RETRIES=3              # retries per download layer (default: 3)
# WISH_DOWNLOAD_TIMEOUT_SECS=300           # per-attempt timeout in seconds (default: 300)
